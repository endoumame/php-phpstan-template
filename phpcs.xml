<?xml version="1.0"?>
<ruleset name="Project">
    <description>PHP_CodeSniffer configuration for php-phpstan-template</description>

    <!-- Scan paths -->
    <file>src</file>
    <file>tests</file>

    <!-- Show progress and use colors -->
    <arg value="ps"/>
    <arg name="colors"/>

    <!-- Use PSR-12 as base standard -->
    <rule ref="PSR12"/>

    <!-- Require strict_types declaration -->
    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- Disallow long array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Require camelCase method names -->
    <rule ref="PSR1.Methods.CamelCapsMethodName"/>

    <!-- Disallow alias functions (sizeof → count, etc.) -->
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="sizeof" value="count"/>
                <element key="delete" value="unset"/>
                <element key="print" value="echo"/>
                <element key="is_null" value="null"/>
                <element key="create_function" value="null"/>
                <element key="var_dump" value="null"/>
                <element key="print_r" value="null"/>
                <element key="debug_zval_dump" value="null"/>
                <element key="var_export" value="null"/>
                <element key="extract" value="null"/>
                <element key="compact" value="null"/>
                <element key="eval" value="null"/>
                <element key="die" value="null"/>
                <element key="dd" value="null"/>
                <element key="dump" value="null"/>
            </property>
        </properties>
    </rule>

    <!-- Disallow trailing whitespace -->
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace"/>

    <!-- Require space after cast -->
    <rule ref="Generic.Formatting.SpaceAfterCast"/>

    <!-- Disallow multiple statements on one line -->
    <rule ref="Generic.Formatting.DisallowMultipleStatements"/>

    <!-- Line length: warn at 120, error at 150 -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="150"/>
        </properties>
    </rule>

    <!-- Exclude vendor directory -->
    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
