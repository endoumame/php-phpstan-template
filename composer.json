{
    "name": "endoumame/php-phpstan-template",
    "description": "Minimal PHP project template with PHPStan static analyzer and PHP_CodeSniffer",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "php-di/php-di": "^7.1",
        "endoumame/php-monad": "^1.3",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15"
    },
    "require-dev": {
        "giorgiosironi/eris": "^1.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
